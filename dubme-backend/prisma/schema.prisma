// Prisma schema for dubme.mn
// Postgres (Supabase). Run `prisma migrate dev --name init` after editing.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

/// One dubbing run from upload to final muxed video.
model Job {
  id              String    @id @default(uuid())
  status          JobStatus @default(UPLOADED)
  /// Optional human-friendly name for the job (editable any time).
  name            String?
  sourceLanguage  String    @default("zh") // ISO 639-1
  targetLanguage  String    @default("mn")
  /// Which TTS engine to use: "gemini" or "chimege"
  ttsProvider     String    @default("gemini")
  voiceName       String? // Gemini voice (e.g. "Kore") or Chimege voice (e.g. "FEMALE3v2")

  /// What to produce: "dub" (replace audio via TTS) or "subtitle" (keep
  /// original audio, only generate subtitles — no TTS).
  outputMode      String    @default("dub")
  /// Burn the subtitles onto the video (hardsub) in addition to the SRT file.
  subtitleBurn    Boolean   @default(false)
  /// Which text the subtitle shows: "translated" (mn), "source" (zh), or
  /// "both" (source on top, translation below).
  subtitleText    String    @default("translated")
  /// Subtitle styling (applied when subtitleBurn=true). All sizes/widths are
  /// px at a 1080p reference height — the burn (.ass with native PlayRes) and
  /// the browser preview both scale them by actualHeight/1080, so the values
  /// mean the same thing everywhere.
  subtitleFontFamily   String  @default("Noto Sans")
  subtitleFontSize     Int     @default(48)   // px @ 1080p reference
  subtitleBold         Boolean @default(false)
  subtitleItalic       Boolean @default(false)
  subtitleTextColor    String  @default("#FFFFFF")  // hex #RRGGBB
  subtitleOutlineWidth Float   @default(3)
  subtitleOutlineColor String  @default("#000000")
  subtitleOutlineAlpha Int     @default(80)   // 0-100 % opaque
  subtitleShadowDepth  Float   @default(0)
  subtitleShadowColor  String  @default("#000000")
  subtitleBgColor      String?                 // hex #RRGGBB, null = no background box
  subtitleBgOpacity    Int     @default(75)   // 0-100 % opaque
  subtitleAlign        String  @default("center") // "left" | "center" | "right"
  subtitleMarginHPct   Int     @default(4)    // L/R margin as % of width
  subtitleLetterSpacing Float  @default(0)    // px @ 1080p reference
  subtitlePosition  String  @default("bottom")   // legacy: kept for backwards compat, no longer read
  /// 0 = top of frame, 100 = bottom; measured to the bottom edge of the text
  /// block (matches ASS Alignment=2 + MarginV). Default 88 = lower-third.
  subtitlePositionPct Int   @default(88)
  /// Dual-language ("both") mode: Chinese line size relative to the main line.
  subtitleZhScale   Float   @default(0.8)
  subtitleZhColor   String?                    // hex, null = same as text colour
  /// Downscale output to 1080p before burning (big speed win on 4K sources).
  capTo1080         Boolean @default(true)

  // Storage object keys (Storj). Full URLs are derived in the service layer.
  inputKey      String? // raw uploaded video
  audioKey      String? // extracted audio (wav)
  outputKey     String? // final muxed video
  subtitleKey   String? // generated SRT

  // Free-text style instructions passed through to Gemini TTS.
  stylePrompt   String?
  temperature   Float?  @default(1.0)

  // Last error, if any.
  errorMessage  String?

  /// Fine-grained progress during long phases (SYNTHESIZING/MUXING): 0-100 +
  /// a human note, so the UI shows movement instead of a frozen spinner.
  progress      Int?    @default(0)
  progressNote  String?

  /// Interactive AI refine runs in the background (like render) — these flag
  /// its in-flight state so the editor can poll without blocking the request.
  refining      Boolean @default(false)
  refineError   String?

  segments      Segment[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([status])
  @@index([createdAt])
}

/// One transcribed/translated/synthesized segment of a Job.
/// Created after STT (sourceText), filled with translatedText after translation,
/// and audioKey is set after TTS.
model Segment {
  id             String   @id @default(uuid())
  jobId          String
  job            Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  /// 0-based index within the job (preserves utterance order).
  sequence       Int

  /// In seconds, from the start of the source audio.
  startSec       Float
  endSec         Float

  sourceText     String  @db.Text
  translatedText String? @db.Text
  audioKey       String?  // per-segment TTS WAV stored in Storj
  audioDuration  Float?   // measured duration of synthesized clip

  /// Detected emotion of the original speaker for this segment
  /// (e.g. "neutral", "happy", "excited", "calm", "sad", "angry").
  emotion        String?

  /// Free-form TTS style hint generated alongside translation
  /// (e.g. "Speak warmly and slowly", "Read with excitement").
  style          String? @db.Text

  /// True when human edited the translatedText after auto-translate.
  edited         Boolean  @default(false)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([jobId, sequence])
  @@index([jobId])
}

enum JobStatus {
  UPLOADED       // file in object storage, nothing else done
  DOWNLOADING    // server-side fetching the input from a user-supplied URL
  EXTRACTING     // ffmpeg pulling audio
  TRANSCRIBING   // Groq Whisper → segments
  TRANSLATING    // Gemini → mongol text
  EDITING        // human review pause (optional)
  SYNTHESIZING   // Gemini TTS → per-segment audio
  MUXING         // ffmpeg combining audio + video
  DONE
  FAILED
}
