# Server
PORT=3001
NODE_ENV=development

# SQLite (default). For production, swap to Postgres:
# DATABASE_URL=postgresql://user:pass@host:5432/dubme
DATABASE_URL=file:./dev.db

# S3-compatible object storage. Defaults are for DigitalOcean Spaces (Singapore).
#   • DigitalOcean Spaces — Cloud Console → API → Spaces Keys
#       endpoint: https://<region>.digitaloceanspaces.com (e.g. sgp1, fra1, nyc3)
#       region:   <same as above prefix>
#   • Storj — https://www.storj.io/ → Buckets → Settings → S3 Credentials
#       endpoint: https://gateway.storjshare.io  region: us1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_REGION=sgp1
S3_BUCKET=dubme

# AI providers
GROQ_API_KEY=                  # https://console.groq.com/keys
GEMINI_API_KEY=                # AQ.... or AIzaSy... from AI Studio
CHIMEGE_TTS_TOKEN=             # /synthesize-specific Chimege token (Mongol-native TTS)
ELEVENLABS_API_KEY=            # optional — for ttsProvider=elevenlabs (expressive v3 TTS)
ELEVENLABS_MODEL=eleven_v3     # or eleven_multilingual_v2 if v3 API access is gated

# Frontend origin for CORS
WEB_ORIGIN=http://localhost:3000
